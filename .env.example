# Application
NODE_ENV=development
PORT=3000
APP_NAME=FinanceDashboard

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finance_db

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=300

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Bcrypt
BCRYPT_ROUNDS=12
